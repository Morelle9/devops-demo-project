pipeline {
    agent any

    environment {
        // Force la version de l'API Docker compatible avec ta VM Ubuntu
        DOCKER_API_VERSION = '1.43'
        // Ton pseudo DockerHub (tu as confirmé que c'est 'admin')
        DOCKER_USER = 'Morelle9'
        IMAGE_NAME = 'demo-java-app'
    }

    parameters {
        string(name: 'build_version', defaultValue: 'V1.0', description: 'Version de l image Docker')
    }

    stages {
        stage('Checkout SCM') {
            steps {
                // Récupération du code source depuis ton dépôt GitHub
                git branch: 'main', url: 'https://github.com/Morelle9/devops-demo-project.git'
            }
        }

        stage('Build & Maven Package') {
            steps {
                // Compilation du projet Java (on saute les tests pour accélérer le lab)
                sh 'cd demo-java-app && mvn clean package -DskipTests'
            }
        }

        stage('SonarQube Analysis') {
            steps {
                // Analyse de la qualité du code avec ton identifiant 'sonarqube'
                withCredentials([string(credentialsId: 'sonarqube', variable: 'SONAR_TOKEN')]) {
                    sh "cd demo-java-app && mvn sonar:sonar -Dsonar.login=$SONAR_TOKEN -Dsonar.host.url=http://sonarqube:9000"
                }
            }
        }

        stage('Docker Build & Push') {
            steps {
                // Connexion à DockerHub et envoi de l'image avec ton identifiant 'dockerhub'
                withCredentials([usernamePassword(credentialsId: 'dockerhub', usernameVariable: 'DUSER', passwordVariable: 'DPASS')]) {
                    sh """
                        echo ${DPASS} | docker login -u ${DUSER} --password-stdin
                        cd demo-java-app
                        docker build -t ${DOCKER_USER}/${IMAGE_NAME}:${params.build_version} .
                        docker push ${DOCKER_USER}/${IMAGE_NAME}:${params.build_version}
                    """
                }
            }
        }

        stage('GitOps: Update Helm Config') {
            steps {
                // Mise à jour automatique du fichier values.yaml avec ton identifiant 'github'
                withCredentials([string(credentialsId: 'github', variable: 'G_TOKEN')]) {
                    sh """
                        git config user.email "wmorelle9@gmail.com"
                        git config user.name "Morelle9"
                        
                        # Modifie la ligne du tag dans le fichier Helm
                        sed -i 's/tag: .*/tag: "${params.build_version}"/' helm/app/values.yaml
                        
                        git add helm/app/values.yaml
                        git commit -m "Jenkins: Mise à jour automatique du tag vers ${params.build_version}" || echo "Pas de changement"
                        
                        # Envoi de la modification vers GitHub
                        git push https://${G_TOKEN}@github.com/Morelle9/devops-demo-project.git HEAD:main
                    """
                }
            }
        }
    }
}
